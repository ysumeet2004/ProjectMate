<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Login · ProjectMate</title>
  </head>
  <body class="pm-body">
    <div class="pm-grid-overlay"></div>

    <%- include('./partials/navbar') %>

    <main class="pm-auth-shell">
      <header class="pm-auth-header">
        <h1 class="pm-auth-title">Welcome back</h1>
        <p class="pm-auth-subtitle">
          Sign in to continue discovering collaborators and managing your projects.
        </p>
      </header>

      <section class="pm-auth-card">
        <form action="/user/login" method="POST" class="d-flex flex-column gap-3">
          <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% } %>
          <div>
            <label class="pm-form-label" for="email">Email</label>
            <input id="email" type="email" name="email" class="pm-input" placeholder="you@example.com" required />
          </div>

          <div>
            <label class="pm-form-label" for="password">Password</label>
            <input id="password" type="password" name="password" class="pm-input" placeholder="Enter your password" required />
          </div>

          <button type="submit" class="pm-btn pm-btn-primary w-100 justify-content-center mt-2">
            Sign in
          </button>
        </form>

        <!-- OAuth Social Login -->
        <div class="pm-auth-divider">
          <span class="pm-divider-text">OR</span>
        </div>

        <div class="pm-oauth-container">
          <a href="/auth/github" class="pm-oauth-btn pm-oauth-github">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.002 12.002 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/>
            </svg>
            <span>Sign in with GitHub</span>
          </a>

          <a href="/auth/google" class="pm-oauth-btn pm-oauth-google">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 12C6 9.239 8.239 7 11 7c1.471 0 2.814.604 3.758 1.574l2.267-2.267C15.316 3.558 13.36 2 11 2 6.858 2 3.294 4.664 2.202 8.335H0v2h2.002C2.002 12 6 16 11 16c2.799 0 5.258-1 7.042-2.646l-2.267-2.267C13.814 11.396 12.471 12 11 12c-2.761 0-5-2.239-5-5z" fill="currentColor"/>
              <path d="M21.999 11h2V9h-2v2zm0 2h2v-2h-2v2z" fill="#EA4335"/>
              <path d="M20 9.5c1.933 0 3.5 1.567 3.5 3.5s-1.567 3.5-3.5 3.5-3.5-1.567-3.5-3.5 1.567-3.5 3.5-3.5z" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>Sign in with Google</span>
          </a>
        </div>

        <div class="pm-auth-footer">
          Don’t have an account?
          <a href="/signup">Create one</a>
        </div>
      </section>
    </main>

    <%- include('./partials/footer') %>
    <%- include('./partials/scripts') %>
  </body>
</html>
