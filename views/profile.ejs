<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>My profile · ProjectMate</title>
  </head>
  <body class="pm-body">
    <div class="pm-grid-overlay"></div>

    <%- include('partials/navbar') %>

    <main class="pm-page">
      <header class="pm-page-header">
        <div>
          <h1 class="pm-page-title">My profile</h1>
          <p class="pm-page-subtitle">
            A simple summary of who you are across ProjectMate. Keep this up to date for better matches.
          </p>
        </div>
      </header>

      <section class="pm-card" style="max-width: 520px;">
        <div class="pm-list">
          <div class="pm-list-row">
            <div class="pm-list-main">Name</div>
            <div class="pm-list-meta"><%= user.name %></div>
          </div>
          <div class="pm-list-row">
            <div class="pm-list-main">Email</div>
            <div class="pm-list-meta"><%= user.email %></div>
          </div>
          <div class="pm-list-row">
            <div class="pm-list-main">User ID</div>
            <div class="pm-list-meta"><%= user._id %></div>
          </div>
        </div>

        <div class="mt-3">
          <a href="/user/logout" class="pm-btn pm-btn-ghost w-100 justify-content-center" style="border-color: var(--pm-danger); color: var(--pm-danger);">
            Log out
          </a>
        </div>
      </section>
    </main>

    <%- include('./partials/footer') %>
    <%- include('./partials/scripts') %>
  </body>
</html>
