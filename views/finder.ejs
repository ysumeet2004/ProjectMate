<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Find projects · ProjectMate</title>
  </head>
  <body class="pm-body">
    <div class="pm-grid-overlay"></div>

    <%- include('./partials/navbar') %>

    <main class="pm-page">
      <header class="pm-page-header">
        <div>
          <h1 class="pm-page-title">Find projects</h1>
          <p class="pm-page-subtitle">
            Filter by domain and explore open projects looking for collaborators right now.
          </p>
        </div>
      </header>

      <!-- Search + Advanced Filters Form -->
      <form action="/project/find" method="GET" class="pm-card mb-4">
        <!-- Search Bar and Filter Button Row -->
        <div style="display: flex; gap: 1rem; align-items: flex-start; margin-bottom: 1.5rem;">
          <div style="flex: 1;">
            <label class="pm-form-label" for="search">Search projects or creators</label>
            <input
              id="search"
              type="text"
              name="search"
              class="pm-input"
              placeholder="project id, project name, or @creator"
              value="<%= typeof search !== 'undefined' ? search : '' %>"
              style="width: 100%;"
            />
            <p class="pm-field-help">
              Type a project name or ID. Prefix with <strong>@</strong> to search by creator name or email
              (for example: <code>@sam</code>).
            </p>
          </div>

          <button 
            type="button" 
            id="filterToggleBtn"
            class="pm-btn pm-btn-secondary" 
            style="white-space: nowrap; padding: 0.75rem 1.5rem; font-weight: 500; border: 2px solid #a78bfa; color: #7c3aed; background: rgba(167, 139, 250, 0.1); align-self: flex-start; margin-top: 1.9rem; cursor: pointer;"
          >
            🔽 Filters
          </button>
        </div>

        <!-- Advanced Filters (Collapsible) -->
        <div id="advancedFilters" style="display: none; padding: 1.5rem; background: rgba(167, 139, 250, 0.08); border-radius: var(--pm-radius-lg); border: 1px solid rgba(167, 139, 250, 0.2); margin-bottom: 1.5rem;">
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
              
          <div>
            <label class="pm-form-label pm-tooltip" data-tooltip="What type of work is needed?">Domain</label>
            <select id="primaryDomain" name="primaryDomain" class="pm-select">
              <option value="all">All domains</option>
              <option value="Web Development" <%= primaryDomain === 'Web Development' ? 'selected' : '' %>>Web Development</option>
              <option value="App Development" <%= primaryDomain === 'App Development' ? 'selected' : '' %>>App Development</option>
              <option value="AI/ML" <%= primaryDomain === 'AI/ML' ? 'selected' : '' %>>AI/ML</option>
              <option value="Blockchain" <%= primaryDomain === 'Blockchain' ? 'selected' : '' %>>Blockchain</option>
              <option value="Cybersecurity" <%= primaryDomain === 'Cybersecurity' ? 'selected' : '' %>>Cybersecurity</option>
              <option value="Game Development" <%= primaryDomain === 'Game Development' ? 'selected' : '' %>>Game Development</option>
              <option value="Other" <%= primaryDomain === 'Other' ? 'selected' : '' %>>Other</option>
            </select>
          </div>

          <div>
            <label class="pm-form-label pm-tooltip" data-tooltip="How much time will it take?">Commitment Level</label>
            <select id="commitment" name="commitment" class="pm-select">
              <option value="">All levels</option>
              <option value="weekend" <% if (typeof commitment !== 'undefined' && commitment === 'weekend') { %>selected<% } %>>🎨 Weekend Project</option>
              <option value="part-time" <% if (typeof commitment !== 'undefined' && commitment === 'part-time') { %>selected<% } %>>⏰ Part-time</option>
              <option value="full-time" <% if (typeof commitment !== 'undefined' && commitment === 'full-time') { %>selected<% } %>>💼 Full-time</option>
            </select>
          </div>

          <div>
            <label class="pm-form-label pm-tooltip" data-tooltip="When does it need to be completed?">Timeline</label>
            <select id="timeline" name="timeline" class="pm-select">
              <option value="">Any timeline</option>
              <option value="urgent" <% if (typeof timeline !== 'undefined' && timeline === 'urgent') { %>selected<% } %>>🚨 Urgent (days)</option>
              <option value="weeks" <% if (typeof timeline !== 'undefined' && timeline === 'weeks') { %>selected<% } %>>📅 Few weeks</option>
              <option value="months" <% if (typeof timeline !== 'undefined' && timeline === 'months') { %>selected<% } %>>📆 Few months</option>
            </select>
          </div>

          <div>
            <label class="pm-form-label pm-tooltip" data-tooltip="How many people are needed?">Team Size</label>
            <select id="teamSize" name="teamSize" class="pm-select">
              <option value="">Any size</option>
              <option value="solo" <% if (typeof teamSize !== 'undefined' && teamSize === 'solo') { %>selected<% } %>>Solo project</option>
              <option value="small" <% if (typeof teamSize !== 'undefined' && teamSize === 'small') { %>selected<% } %>>Small (2-3 people)</option>
              <option value="medium" <% if (typeof teamSize !== 'undefined' && teamSize === 'medium') { %>selected<% } %>>Medium (4-5 people)</option>
              <option value="large" <% if (typeof teamSize !== 'undefined' && teamSize === 'large') { %>selected<% } %>>Large (5+ people)</option>
            </select>
          </div>

            <div>
              <label class="pm-form-label" for="experience">Experience Level</label>
              <select id="experience" name="experience" class="pm-select">
                <option value="">Any experience</option>
                <option value="beginner" <% if (typeof experience !== 'undefined' && experience === 'beginner') { %>selected<% } %>>Beginner-friendly</option>
                <option value="intermediate" <% if (typeof experience !== 'undefined' && experience === 'intermediate') { %>selected<% } %>>Intermediate</option>
                <option value="advanced" <% if (typeof experience !== 'undefined' && experience === 'advanced') { %>selected<% } %>>Advanced</option>
              </select>
            </div>
          </div>
        </div>

        <button type="submit" class="pm-btn pm-btn-primary justify-content-center" style="width: 100%; margin-top: 1rem;">
          Search
        </button>
      </form>

      <!-- Project List -->
      <section class="pm-section-grid">
    <% if (projects && projects.length > 0) { %>
      <% projects.forEach(project => { %>
        <article class="pm-card">
          <div class="pm-card-header">
            <div>
              <div class="pm-card-title"><%= project.title %></div>
              <div class="pm-card-subtitle"><%= project.domain %></div>
            </div>
            <div class="pm-pill pm-tooltip" data-tooltip="Remaining open positions">
              📍 <%= Math.max((project.maxApplicants || 1) - (((project.approved_users && project.approved_users.length) || 0)), 0) %>
            </div>
          </div>
          <p class="pm-card-subtitle mb-2"><%= project.desc %></p>
          <p class="pm-card-subtitle">
            <strong>Skills:</strong>
            <%- (project.skills_req && typeof project.skills_req.join === 'function')
                ? project.skills_req.map(s => '<span class="pm-skill-tag">' + s.trim() + '</span>').join('')
                : (project.skills_req && typeof project.skills_req === 'string') ? project.skills_req.split(',').map(s => '<span class="pm-skill-tag">' + s.trim() + '</span>').join('') : 'None specified' %>
          </p>
          
          <!-- Commitment & Timeline Badges -->
          <div class="mt-2 d-flex gap-2 flex-wrap">
            <% if (project.commitment) { %>
              <span class="pm-commitment-badge <%= project.commitment === 'Full-time' ? 'pm-commitment-full' : project.commitment === 'Part-time' ? 'pm-commitment-part' : 'pm-commitment-weekend' %> pm-tooltip" 
                    data-tooltip="<%= project.commitment === 'Full-time' ? 'Needs full-time commitment' : project.commitment === 'Part-time' ? 'Part-time work acceptable' : 'Flexible weekend work' %>">
                <span><%= project.commitment === 'Full-time' ? '💼' : project.commitment === 'Part-time' ? '⏰' : '🎨' %></span>
                <span><%= project.commitment %></span>
              </span>
            <% } %>
            <% if (project.timeline) { %>
              <span class="pm-tooltip" data-tooltip="Estimated completion timeline">
                <% if (project.timeline === 'Urgent') { %>
                  <span style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.35rem 0.7rem; border-radius: 6px; background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); font-size: 0.8rem; font-weight: 600; color: #ef4444;">🚨 <%= project.timeline %></span>
                <% } else if (project.timeline === 'Few weeks') { %>
                  <span style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.35rem 0.7rem; border-radius: 6px; background: rgba(251, 146, 60, 0.15); border: 1px solid rgba(251, 146, 60, 0.3); font-size: 0.8rem; font-weight: 600; color: #f97316;">📅 <%= project.timeline %></span>
                <% } else { %>
                  <span style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.35rem 0.7rem; border-radius: 6px; background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3); font-size: 0.8rem; font-weight: 600; color: #22c55e;">📆 <%= project.timeline %></span>
                <% } %>
              </span>
            <% } %>
          </div>

          <div class="d-flex flex-column gap-2 mt-3">
            <span class="pm-list-meta pm-tooltip" data-tooltip="When this project was posted">📅 Created <%= new Date(project.createdOn).toLocaleDateString() %></span>
            <%
              const hasApplied =
                project.applicants &&
                project.applicants.some(applicant => applicant.user && applicant.user._id.toString() === currentUserId);
            %>
            <% if (hasApplied) { %>
              <button class="pm-btn pm-btn-ghost w-100 justify-content-center pm-tooltip" data-tooltip="You've already applied to this project" disabled>✓ Applied</button>
            <% } else { %>
              <form action="/project/apply/<%= project._id %>" method="POST">
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <button type="submit" class="pm-btn pm-btn-primary w-100 justify-content-center pm-tooltip" data-tooltip="Express interest and join this project">
                  Apply
                </button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <%- include('./partials/empty-state', {
        icon: '🔍',
        title: 'No projects found',
        subtitle: search ? 'Try adjusting your search or filters to find more projects' : 'No open projects available right now. Check back soon!',
        action: { text: 'Create a Project', url: '/project/create' },
        secondaryAction: search ? { text: 'Clear Filters', url: '/project/find' } : null
      }) %>
    <% } %>
      </section>
    </main>

    <%- include('./partials/footer') %>
    <%- include('./partials/scripts') %>
    
    <script>
      // Toggle filters visibility
      function toggleFilters() {
        const filters = document.getElementById('advancedFilters');
        const btn = document.getElementById('filterToggleBtn');
        
        if (!filters) {
          console.error('advancedFilters element not found');
          return;
        }
        
        const isHidden = filters.style.display === 'none' || filters.style.display === '';
        filters.style.display = isHidden ? 'block' : 'none';
        
        // Update button text
        btn.textContent = isHidden ? '🔼 Filters' : '🔽 Filters';
      }

      // Attach click event to filter button
      document.addEventListener('DOMContentLoaded', function() {
        const btn = document.getElementById('filterToggleBtn');
        if (btn) {
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            toggleFilters();
          });
        }
      });

      (function () {
        const input = document.getElementById('search');
        if (!input) return;

        function updateMentionState() {
          const value = input.value.trim();
          if (value.startsWith('@') && value.length > 1) {
            input.classList.add('pm-input-mention');
          } else {
            input.classList.remove('pm-input-mention');
          }
        }

        input.addEventListener('input', updateMentionState);
        document.addEventListener('DOMContentLoaded', updateMentionState);
        updateMentionState();
      })();
    </script>
  </body>
</html>
