<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>ProjectMate · Build Together, Grow Together</title>
  </head>
  <body class="pm-body">
    <div class="pm-grid-overlay"></div>

    <%- include('./partials/navbar') %>

    <main class="pm-page" id="main-content" style="min-height: 80vh;" tabindex="-1">
      <!-- Hero Section -->
      <section class="pm-hero-shell" style="padding: 4rem 1.5rem; display: grid; grid-template-columns: 1fr 420px; gap: 2rem; align-items: center; max-width: 1200px; margin: 0 auto;">
        <div>
          <div class="pm-hero-kicker">The Future of Collaboration</div>
          <h1 class="pm-hero-title" style="margin-top: 0.4rem;">Stop building alone. Find your team, ship together.</h1>
          <p class="pm-hero-subtitle" style="margin-top: 1rem; max-width: 620px;">ProjectMate is where talented makers, developers, and creators connect to build remarkable things. No more LinkedIn cold messages. No more hunting for collaborators. Just the right people, at the right time, on the right projects.</p>

          <div style="margin-top: 1.2rem; display: flex; gap: 0.8rem; font-size: 0.9rem; color: rgba(255,255,255,0.7);">
            <span style="display: flex; align-items: center; gap: 0.4rem;">
              <span style="width: 5px; height: 5px; background: #a855f7; border-radius: 50%;"></span>
              Join 5,000+ creators
            </span>
            <span style="display: flex; align-items: center; gap: 0.4rem;">
              <span style="width: 5px; height: 5px; background: #ec4899; border-radius: 50%;"></span>
              1,200+ active projects
            </span>
          </div>

          <div class="pm-hero-actions" style="margin-top: 2rem; display:flex; gap:1rem; align-items:center;">
            <a href="/signup" class="pm-btn pm-btn-primary">Start Your Journey</a>
            <a href="/project/find" class="pm-btn pm-btn-secondary">Explore Projects</a>
          </div>

          <!-- Trust Signals -->
          <div style="margin-top: 2.5rem; padding-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.1);">
            <p style="font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 1rem; font-weight: 500;">TRUSTED BY INNOVATORS WORLDWIDE</p>
            <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
              <div style="text-align: center;">
                <div style="font-size: 1.8rem; font-weight: 700; color: #a855f7;">4.9★</div>
                <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">Community Rating</div>
              </div>
              <div style="text-align: center;">
                <div style="font-size: 1.8rem; font-weight: 700; color: #ec4899;">48h</div>
                <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">Average Team Match</div>
              </div>
              <div style="text-align: center;">
                <div style="font-size: 1.8rem; font-weight: 700; color: #06b6d4;">87%</div>
                <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">Project Success Rate</div>
              </div>
            </div>
          </div>
        </div>

        <aside class="pm-hero-visual" id="heroVisual" role="img" aria-label="Interactive preview showing project tiles and active collaborators">
          <div class="pm-hero-bg"></div>
          <div class="pm-hero-overlay"></div>

          <div class="pm-visual-content">
            <div class="pm-visual-panel">
              <div class="pm-panel-row">
                <div class="dot"></div>
                <div class="line"></div>
                <div class="chip" style="width:60%;"></div>
              </div>
              <div class="pm-panel-row small">
                <div class="chip" style="width:90%;"></div>
              </div>
              <div class="pm-panel-grid">
                <div class="cell"></div>
                <div class="cell active"></div>
                <div class="cell"></div>
                <div class="cell"></div>
                <div class="cell active"></div>
                <div class="cell"></div>
              </div>
            </div>
            <div class="pm-visual-credits">Realtime collaboration • 12 active</div>
          </div>
        </aside>
      </section>

      <!-- Value Proposition Section -->
      <section style="padding: 4rem 1.5rem; background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(236, 72, 153, 0.05) 100%); margin-top: 3rem;">
        <div style="max-width: 1200px; margin: 0 auto;">
          <div style="text-align: center; margin-bottom: 3rem;">
            <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">Why thousands choose ProjectMate</h2>
            <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 0 auto; font-size: 1.1rem;">We've spent years perfecting how creative minds connect and collaborate. Here's what makes us different.</p>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
            <!-- Benefit Card 1 -->
            <div style="background: rgba(15, 15, 15, 0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); padding: 2rem; border-radius: 12px; hover: transform 0.3s ease;">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                <div style="width: 40px; height: 40px; background: rgba(168, 85, 247, 0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">🎯</div>
                <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0;">Smart Matching</h3>
              </div>
              <p style="color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.6;">Our algorithm understands your skills, goals, and work style. Find collaborators who are genuinely aligned with your vision—not just anyone with a portfolio.</p>
            </div>

            <!-- Benefit Card 2 -->
            <div style="background: rgba(15, 15, 15, 0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); padding: 2rem; border-radius: 12px;">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                <div style="width: 40px; height: 40px; background: rgba(236, 72, 153, 0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">🚀</div>
                <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0;">Built-in Tools</h3>
              </div>
              <p style="color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.6;">Messaging, project tracking, collaboration features—everything you need is built right in. No switching between 5 different apps. Just one platform that works.</p>
            </div>

            <!-- Benefit Card 3 -->
            <div style="background: rgba(15, 15, 15, 0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); padding: 2rem; border-radius: 12px;">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                <div style="width: 40px; height: 40px; background: rgba(6, 182, 212, 0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">🤝</div>
                <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0;">Real Community</h3>
              </div>
              <p style="color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.6;">This isn't just a marketplace. It's a community of makers who support each other. Share learnings, celebrate wins, and grow together beyond individual projects.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Social Proof / Testimonial Section -->
      <section style="padding: 4rem 1.5rem; margin-top: 3rem;">
        <div style="max-width: 1200px; margin: 0 auto;">
          <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 3rem; text-align: center;">Stories from our community</h2>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem;">
            <!-- Testimonial 1 -->
            <div style="background: rgba(15, 15, 15, 0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); padding: 2rem; border-radius: 12px;">
              <div style="display: flex; gap: 0.3rem; margin-bottom: 1rem;">⭐⭐⭐⭐⭐</div>
              <p style="color: rgba(255,255,255,0.9); font-size: 0.95rem; line-height: 1.7; margin-bottom: 1.5rem; font-style: italic;">"ProjectMate saved me months of searching. I found three collaborators within a week—designers, developers, and a marketer. We shipped our MVP in 8 weeks."</p>
              <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="width: 40px; height: 40px; background: linear-gradient(135deg, #a855f7, #ec4899); border-radius: 50%;"></div>
                <div>
                  <div style="font-weight: 600; font-size: 0.9rem;">Sarah Chen</div>
                  <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">Founder, Design Studio</div>
                </div>
              </div>
            </div>

            <!-- Testimonial 2 -->
            <div style="background: rgba(15, 15, 15, 0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); padding: 2rem; border-radius: 12px;">
              <div style="display: flex; gap: 0.3rem; margin-bottom: 1rem;">⭐⭐⭐⭐⭐</div>
              <p style="color: rgba(255,255,255,0.9); font-size: 0.95rem; line-height: 1.7; margin-bottom: 1.5rem; font-style: italic;">"As a solo developer, finding the right people to work with was the hardest part. ProjectMate completely changed that. The quality of matches is exceptional."</p>
              <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="width: 40px; height: 40px; background: linear-gradient(135deg, #06b6d4, #8b5cf6); border-radius: 50%;"></div>
                <div>
                  <div style="font-weight: 600; font-size: 0.9rem;">Marcus Johnson</div>
                  <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">Full-Stack Engineer</div>
                </div>
              </div>
            </div>

            <!-- Testimonial 3 -->
            <div style="background: rgba(15, 15, 15, 0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); padding: 2rem; border-radius: 12px;">
              <div style="display: flex; gap: 0.3rem; margin-bottom: 1rem;">⭐⭐⭐⭐⭐</div>
              <p style="color: rgba(255,255,255,0.9); font-size: 0.95rem; line-height: 1.7; margin-bottom: 1.5rem; font-style: italic;">"Not just a tool—it's a community. The people here elevate each other. I've made real friends and amazing collaborators through ProjectMate."</p>
              <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="width: 40px; height: 40px; background: linear-gradient(135deg, #ec4899, #f59e0b); border-radius: 50%;"></div>
                <div>
                  <div style="font-weight: 600; font-size: 0.9rem;">Emma Rodriguez</div>
                  <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">Product Designer & Founder</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section style="padding: 4rem 1.5rem; margin-top: 3rem; text-align: center;">
        <div style="max-width: 800px; margin: 0 auto;">
          <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">Ready to build something exceptional?</h2>
          <p style="color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 2rem; line-height: 1.6;">Your next great collaboration is just a few clicks away. Join thousands of creators who are already building together.</p>
          
          <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <a href="/signup" class="pm-btn pm-btn-primary" style="padding: 0.9rem 2rem; font-size: 1rem;">Create Your Profile</a>
            <a href="/project/find" class="pm-btn pm-btn-secondary" style="padding: 0.9rem 2rem; font-size: 1rem;">Browse Projects Now</a>
          </div>

          <p style="margin-top: 2rem; font-size: 0.85rem; color: rgba(255,255,255,0.5);">No credit card required • Join free • Cancel anytime</p>
        </div>
      </section>
    </main>

    <%- include('./partials/footer') %>
    <%- include('./partials/scripts') %>
    <script>
      (function(){
        const hero = document.getElementById('heroVisual');
        if (!hero) return;

        // Update CSS variables to create a spotlight reveal following cursor
        hero.addEventListener('mousemove', (e) => {
          const rect = hero.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          hero.style.setProperty('--mx', x + 'px');
          hero.style.setProperty('--my', y + 'px');
        });

        hero.addEventListener('mouseenter', () => hero.classList.add('hover'));
        hero.addEventListener('mouseleave', () => hero.classList.remove('hover'));
      })();
    </script>
  </body>
</html>

