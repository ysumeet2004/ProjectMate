<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Settings · ProjectMate</title>
  </head>
  <body class="pm-body">
    <div class="pm-grid-overlay"></div>

    <%- include('partials/navbar') %>

    <main class="pm-page" id="main-content" tabindex="-1">
      <header class="pm-page-header">
        <div>
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
            <h1 class="pm-page-title" style="margin-bottom: 0;">Account Settings</h1>
            <span style="display: inline-block; background: var(--pm-accent-soft); color: var(--pm-accent-strong); padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">PRIVATE</span>
          </div>
          <p class="pm-page-subtitle">Manage your account security, privacy, and collaboration preferences</p>
        </div>
      </header>

      <div style="max-width: 900px; display: flex; flex-direction: column; gap: 2rem;">
        
        <!-- ============================================
             SECTION 1: ACCOUNT SETTINGS
             ============================================ -->
        <div class="pm-card">
          <div class="pm-form-header mb-4">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--pm-accent);"><circle cx="12" cy="12" r="1"></circle><path d="M12 1v6m0 6v6"></path><path d="M4.22 4.22l4.24 4.24m3.08 0l3.08 3.08M19.78 19.78l-4.24-4.24m-3.08 0l-3.08-3.08M1 12a11 11 0 0 1 22 0 11 11 0 0 1-22 0"></path></svg>
              <h3 class="pm-card-title mb-0">Account Settings</h3>
            </div>
            <p class="pm-form-description">Update your core account information and security settings</p>
          </div>

          <!-- Email Display (read-only) -->
          <div class="pm-form-group">
            <label class="pm-form-label">Email Address</label>
            <p class="pm-form-sublabel">Your account login and primary contact</p>
            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--pm-border-subtle); border-radius: 8px;">
              <span class="pm-list-meta"><%= user.email %></span>
              <span style="display: inline-block; background: var(--pm-success); color: white; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase;">verified</span>
            </div>
            <p class="pm-form-helper">Contact support to change your email address</p>
          </div>

          <!-- Change Password Form -->
          <form action="/user/settings" method="POST" id="passwordForm" class="pm-form" style="margin-top: 2rem;">
            <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <input type="hidden" name="action" value="changePassword">

            <div class="pm-form-group">
              <label for="currentPassword" class="pm-form-label">Current Password</label>
              <p class="pm-form-sublabel">Enter your current password to make changes</p>
              <input
                id="currentPassword"
                type="password"
                name="currentPassword"
                class="pm-input"
                placeholder="••••••••"
                required
              />
            </div>

            <div class="pm-form-group">
              <label for="newPassword" class="pm-form-label">New Password</label>
              <p class="pm-form-sublabel">Must be at least 8 characters</p>
              <input
                id="newPassword"
                type="password"
                name="newPassword"
                class="pm-input"
                placeholder="••••••••"
                minlength="8"
                required
              />
            </div>

            <div class="pm-form-group">
              <label for="confirmPassword" class="pm-form-label">Confirm Password</label>
              <p class="pm-form-sublabel">Re-enter your new password</p>
              <input
                id="confirmPassword"
                type="password"
                name="confirmPassword"
                class="pm-input"
                placeholder="••••••••"
                minlength="8"
                required
              />
            </div>

            <button type="submit" class="pm-btn pm-btn-primary">
              <span>Update Password</span>
            </button>
          </form>
        </div>

        <!-- ============================================
             SECTION 2: PRIVACY & VISIBILITY
             ============================================ -->
        <div class="pm-card">
          <div class="pm-form-header mb-4">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--pm-accent);"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              <h3 class="pm-card-title mb-0">Privacy & Visibility</h3>
            </div>
            <p class="pm-form-description">Control what information is visible to other users</p>
          </div>

          <form action="/user/settings" method="POST" class="pm-form">
            <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <input type="hidden" name="action" value="updatePrivacy">

            <!-- Profile Visibility -->
            <div class="pm-form-group">
              <label class="pm-form-label">Profile Visibility</label>
              <p class="pm-form-sublabel">Control who can see your profile</p>
              <div style="display: flex; flex-direction: column; gap: 1rem;">
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="radio" name="profileVisibility" value="public" class="pm-checkbox-input" <%= (user.profileVisibility === 'public' || !user.profileVisibility) ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">Public (Anyone can view)</span>
                </label>
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="radio" name="profileVisibility" value="private" class="pm-checkbox-input" <%= user.profileVisibility === 'private' ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">Private (Only you can view)</span>
                </label>
              </div>
            </div>

            <!-- Show Phone Number -->
            <div class="pm-form-group" style="margin-top: 2rem;">
              <label class="pm-form-label">Contact Information</label>
              <p class="pm-form-sublabel">Choose what to display on your profile</p>
              <label class="pm-checkbox-label" style="margin: 0;">
                <input type="checkbox" name="showEmail" class="pm-checkbox-input" <%= user.showEmail ? 'checked' : '' %> />
                <span class="pm-checkbox-text">Show my email address</span>
              </label>
              <label class="pm-checkbox-label" style="margin: 1rem 0 0 0;">
                <input type="checkbox" name="showPhone" class="pm-checkbox-input" <%= user.showPhone ? 'checked' : '' %> />
                <span class="pm-checkbox-text">Show my phone number</span>
              </label>
            </div>

            <!-- Project History Visibility -->
            <div class="pm-form-group" style="margin-top: 2rem;">
              <label class="pm-form-label">Project History</label>
              <p class="pm-form-sublabel">Control visibility of your collaboration history</p>
              <label class="pm-checkbox-label" style="margin: 0;">
                <input type="checkbox" name="showProjectHistory" class="pm-checkbox-input" <%= user.showProjectHistory !== false ? 'checked' : '' %> />
                <span class="pm-checkbox-text">Show my completed projects</span>
              </label>
            </div>

            <button type="submit" class="pm-btn pm-btn-primary" style="margin-top: 2rem;">
              <span>Save Privacy Settings</span>
            </button>
          </form>
        </div>

        <!-- ============================================
             SECTION 3: NOTIFICATION PREFERENCES
             ============================================ -->
        <div class="pm-card">
          <div class="pm-form-header mb-4">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--pm-accent);"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
              <h3 class="pm-card-title mb-0">Notification Preferences</h3>
            </div>
            <p class="pm-form-description">Manage how you receive updates about your projects and applications</p>
          </div>

          <form action="/user/settings" method="POST" class="pm-form">
            <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <input type="hidden" name="action" value="updateNotifications">

            <div class="pm-form-group">
              <label class="pm-form-label">Email Notifications</label>
              <p class="pm-form-sublabel">Receive updates about your applications and projects</p>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="checkbox" name="notifyApplications" class="pm-checkbox-input" <%= user.notifyApplications !== false ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">New applications on my projects</span>
                </label>
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="checkbox" name="notifyApplicationStatus" class="pm-checkbox-input" <%= user.notifyApplicationStatus !== false ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">Application status changes (accepted/rejected)</span>
                </label>
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="checkbox" name="notifyMessages" class="pm-checkbox-input" <%= user.notifyMessages !== false ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">New messages from collaborators</span>
                </label>
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="checkbox" name="notifyProjectUpdates" class="pm-checkbox-input" <%= user.notifyProjectUpdates !== false ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">Updates from projects I joined</span>
                </label>
              </div>
            </div>

            <div class="pm-form-group" style="margin-top: 2rem;">
              <label for="notificationFrequency" class="pm-form-label">Notification Frequency</label>
              <p class="pm-form-sublabel">How often to receive digest emails</p>
              <select id="notificationFrequency" name="notificationFrequency" class="pm-select">
                <option value="immediate" <%= user.notificationFrequency === 'immediate' ? 'selected' : '' %>>Immediate</option>
                <option value="daily" <%= user.notificationFrequency === 'daily' ? 'selected' : '' %>>Daily digest</option>
                <option value="weekly" <%= user.notificationFrequency === 'weekly' ? 'selected' : '' %>>Weekly digest</option>
                <option value="none" <%= user.notificationFrequency === 'none' ? 'selected' : '' %>>Never</option>
              </select>
            </div>

            <button type="submit" class="pm-btn pm-btn-primary" style="margin-top: 2rem;">
              <span>Save Notification Settings</span>
            </button>
          </form>
        </div>

        <!-- ============================================
             SECTION 4: CONNECTED ACCOUNTS
             ============================================ -->
        <div class="pm-card">
          <div class="pm-form-header mb-4">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--pm-accent);"><circle cx="12" cy="12" r="1"></circle><path d="M12 1v6m0 6v6"></path><path d="M4.22 4.22l4.24 4.24m3.08 0l3.08 3.08M19.78 19.78l-4.24-4.24m-3.08 0l-3.08-3.08"></path></svg>
              <h3 class="pm-card-title mb-0">Connected Accounts</h3>
            </div>
            <p class="pm-form-description">Manage your third-party account integrations</p>
          </div>

          <!-- GitHub -->
          <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--pm-border-subtle); border-radius: 8px; margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; gap: 1rem;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="color: var(--pm-text);"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              <div>
                <div style="font-weight: 600; color: var(--pm-text); font-size: 0.95rem;">GitHub</div>
                <div style="font-size: 0.85rem; color: var(--pm-subtext);">
                  <% if (user.githubId) { %>
                    Connected as <strong><%= user.githubProfile?.login || 'user' %></strong>
                  <% } else { %>
                    Not connected
                  <% } %>
                </div>
              </div>
            </div>
            <% if (user.githubId) { %>
              <form action="/user/settings" method="POST" style="display: inline;">
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <input type="hidden" name="action" value="disconnectGithub">
                <button type="submit" class="pm-btn pm-btn-ghost" onclick="return confirm('Disconnect GitHub account?')">
                  <span>Disconnect</span>
                </button>
              </form>
            <% } else { %>
              <a href="/auth/github" class="pm-btn pm-btn-primary">
                <span>Connect</span>
              </a>
            <% } %>
          </div>

          <!-- Google -->
          <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--pm-border-subtle); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 1rem;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="color: var(--pm-text);"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              <div>
                <div style="font-weight: 600; color: var(--pm-text); font-size: 0.95rem;">Google</div>
                <div style="font-size: 0.85rem; color: var(--pm-subtext);">
                  <% if (user.googleId) { %>
                    Connected as <strong><%= user.googleProfile?.email || 'user' %></strong>
                  <% } else { %>
                    Not connected
                  <% } %>
                </div>
              </div>
            </div>
            <% if (user.googleId) { %>
              <form action="/user/settings" method="POST" style="display: inline;">
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <input type="hidden" name="action" value="disconnectGoogle">
                <button type="submit" class="pm-btn pm-btn-ghost" onclick="return confirm('Disconnect Google account?')">
                  <span>Disconnect</span>
                </button>
              </form>
            <% } else { %>
              <a href="/auth/google" class="pm-btn pm-btn-primary">
                <span>Connect</span>
              </a>
            <% } %>
          </div>
        </div>

        <!-- ============================================
             SECTION 5: COLLABORATION PREFERENCES
             ============================================ -->
        <div class="pm-card">
          <div class="pm-form-header mb-4">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--pm-accent);"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              <h3 class="pm-card-title mb-0">Collaboration Preferences</h3>
            </div>
            <p class="pm-form-description">Set your default project preferences and collaboration style</p>
          </div>

          <form action="/user/settings" method="POST" class="pm-form">
            <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <input type="hidden" name="action" value="updateCollaboration">

            <!-- Default Commitment Level -->
            <div class="pm-form-group">
              <label for="defaultCommitment" class="pm-form-label">Default Commitment Level</label>
              <p class="pm-form-sublabel">Your preferred time commitment for projects</p>
              <select id="defaultCommitment" name="defaultCommitment" class="pm-select">
                <option value="flexible" <%= user.defaultCommitment === 'flexible' ? 'selected' : '' %>>Flexible</option>
                <option value="part-time" <%= user.defaultCommitment === 'part-time' ? 'selected' : '' %>>Part-time (5-10 hrs/week)</option>
                <option value="full-time" <%= user.defaultCommitment === 'full-time' ? 'selected' : '' %>>Full-time (25+ hrs/week)</option>
                <option value="weekend" <%= user.defaultCommitment === 'weekend' ? 'selected' : '' %>>Weekend projects only</option>
              </select>
            </div>

            <!-- Experience Level -->
            <div class="pm-form-group" style="margin-top: 2rem;">
              <label for="experienceLevel" class="pm-form-label">Experience Level</label>
              <p class="pm-form-sublabel">Your professional experience in your field</p>
              <select id="experienceLevel" name="experienceLevel" class="pm-select">
                <option value="beginner" <%= user.experienceLevel === 'beginner' ? 'selected' : '' %>>Beginner</option>
                <option value="intermediate" <%= user.experienceLevel === 'intermediate' ? 'selected' : '' %>>Intermediate</option>
                <option value="advanced" <%= user.experienceLevel === 'advanced' ? 'selected' : '' %>>Advanced</option>
                <option value="expert" <%= user.experienceLevel === 'expert' ? 'selected' : '' %>>Expert</option>
              </select>
            </div>

            <!-- Collaboration Style -->
            <div class="pm-form-group" style="margin-top: 2rem;">
              <label class="pm-form-label">Preferred Collaboration Style</label>
              <p class="pm-form-sublabel">How you like to work with others</p>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="checkbox" name="collabAsync" class="pm-checkbox-input" <%= user.collabAsync ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">Asynchronous (flexible time zones)</span>
                </label>
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="checkbox" name="collabMeetings" class="pm-checkbox-input" <%= user.collabMeetings ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">Regular meetings / sync-ups</span>
                </label>
                <label class="pm-checkbox-label" style="margin: 0;">
                  <input type="checkbox" name="collabOpenFeedback" class="pm-checkbox-input" <%= user.collabOpenFeedback ? 'checked' : '' %> />
                  <span class="pm-checkbox-text">Direct and open feedback culture</span>
                </label>
              </div>
            </div>

            <button type="submit" class="pm-btn pm-btn-primary" style="margin-top: 2rem;">
              <span>Save Collaboration Preferences</span>
            </button>
          </form>
        </div>

        <!-- ============================================
             SECTION 6: DANGER ZONE
             ============================================ -->
        <div class="pm-card" style="border-color: var(--pm-danger); background: rgba(255, 107, 107, 0.03);">
          <div class="pm-form-header mb-4">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--pm-danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3.05h16.94a2 2 0 0 0 1.71-3.05L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
              <h3 class="pm-card-title mb-0" style="color: var(--pm-danger);">Danger Zone</h3>
            </div>
            <p class="pm-form-description">Irreversible account actions</p>
          </div>

          <!-- Download Data -->
          <div style="padding: 1.5rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--pm-border-subtle); border-radius: 8px; margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <div>
                <div style="font-weight: 600; color: var(--pm-text); font-size: 0.95rem;">Download Your Data</div>
                <p class="pm-form-sublabel" style="margin: 0.5rem 0 0 0;">Get a copy of all your personal data</p>
              </div>
              <form action="/user/settings" method="POST" style="display: inline;">
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <input type="hidden" name="action" value="downloadData">
                <button type="submit" class="pm-btn pm-btn-ghost">
                  <span>Download</span>
                </button>
              </form>
            </div>
          </div>

          <!-- Deactivate Account -->
          <div style="padding: 1.5rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--pm-border-subtle); border-radius: 8px; margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <div>
                <div style="font-weight: 600; color: var(--pm-text); font-size: 0.95rem;">Deactivate Account</div>
                <p class="pm-form-sublabel" style="margin: 0.5rem 0 0 0;">Temporarily hide your profile. You can reactivate anytime.</p>
              </div>
              <form action="/user/settings" method="POST" style="display: inline;">
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <input type="hidden" name="action" value="deactivateAccount">
                <button type="submit" class="pm-btn pm-btn-ghost" onclick="return confirm('Are you sure you want to deactivate your account? You can reactivate it anytime.')">
                  <span>Deactivate</span>
                </button>
              </form>
            </div>
          </div>

          <!-- Delete Account -->
          <div style="padding: 1.5rem; background: rgba(255, 107, 107, 0.1); border: 1px solid var(--pm-danger); border-radius: 8px;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <div>
                <div style="font-weight: 600; color: var(--pm-danger); font-size: 0.95rem;">Delete Account</div>
                <p class="pm-form-sublabel" style="margin: 0.5rem 0 0 0; color: var(--pm-danger);">Permanently delete your account and all associated data</p>
              </div>
              <form action="/user/settings" method="POST" style="display: inline;">
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <input type="hidden" name="action" value="deleteAccount">
                <button type="submit" class="pm-btn pm-btn-outline-danger" onclick="return confirm('WARNING: This action is PERMANENT and cannot be undone. All your data will be deleted. Type DELETE to confirm.')">
                  <span>Delete Account</span>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/scripts') %>
    <script>
      // Password confirmation validation
      const passwordForm = document.getElementById('passwordForm');
      if (passwordForm) {
        passwordForm.addEventListener('submit', function(e) {
          const newPassword = document.getElementById('newPassword').value;
          const confirmPassword = document.getElementById('confirmPassword').value;
          
          if (newPassword !== confirmPassword) {
            e.preventDefault();
            alert('Passwords do not match!');
            return false;
          }
          
          if (newPassword.length < 8) {
            e.preventDefault();
            alert('Password must be at least 8 characters!');
            return false;
          }
        });
      }

      // Show success message if settings were updated
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('success') === 'true') {
        const section = urlParams.get('section');
        if (section) {
          alert('Settings updated successfully!');
        }
      }

      // Show error message if there was an issue
      if (urlParams.get('error') === 'true') {
        const message = urlParams.get('message') || 'An error occurred';
        alert('Error: ' + decodeURIComponent(message));
      }
    </script>
  </body>
</html>
