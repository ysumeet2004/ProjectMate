<div class="pm-card" style="display: flex; flex-direction: column;">
  <div class="pm-card-header">
    <div>
      <div class="pm-card-title"><%= project.title %></div>
    </div>
  </div>
  <p class="pm-card-subtitle mb-2"><%= project.desc %></p>

  <div style="flex: 1; margin-top: auto;">
    <p class="pm-card-subtitle mb-2"><strong>Domain:</strong> <%= project.domain %></p>
    <p class="pm-card-subtitle mb-2">
      <strong>Skills Required:</strong> 
      <% if (typeof project.skills_req === 'object' && project.skills_req.join) { %>
        <%-  project.skills_req.map(s => '<span class="pm-skill-tag">' + s.trim() + '</span>').join('') %>
      <% } else if (typeof project.skills_req === 'string') { %>
        <%-  project.skills_req.split(',').map(s => '<span class="pm-skill-tag">' + s.trim() + '</span>').join('') %>
      <% } else { %>
        None specified
      <% } %>
    </p>
    <p class="pm-card-subtitle text-sm" style="color: var(--pm-subtext); margin-bottom: 1rem;">
      Created On: <%= new Date(project.createdOn).toLocaleDateString() %>
    </p>

    <% if (project.applicants && project.applicants.length > 0) { %>
      <a href="/project/<%= project._id %>/applicants" class="pm-pill" style="display: inline-block;">
        👥 Applicants: <%= project.applicants.length %>
      </a>
    <% } else { %>
      <div class="pm-pill" style="display: inline-block; background: var(--pm-border-strong);">No Applicants Yet</div>
    <% } %>
  </div>
</div>
