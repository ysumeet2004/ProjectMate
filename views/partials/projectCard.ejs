<div class="pm-card">
  <div class="pm-card-header">
    <div>
      <div class="pm-card-title"><%= project.title %></div>
      <div class="pm-card-subtitle"><%= project.domain %></div>
    </div>
  </div>
  <p class="pm-card-subtitle mb-2"><%= project.desc %></p>
  <p class="pm-card-subtitle mb-2">
    <strong>Skills Required:</strong> 
    <% if (typeof project.skills_req === 'object' && project.skills_req.join) { %>
      <%-  project.skills_req.map(s => '<span class="pm-skill-tag">' + s.trim() + '</span>').join('') %>
    <% } else if (typeof project.skills_req === 'string') { %>
      <%-  project.skills_req.split(',').map(s => '<span class="pm-skill-tag">' + s.trim() + '</span>').join('') %>
    <% } else { %>
      None specified
    <% } %>
  </p>
  <p class="pm-card-subtitle text-sm" style="color: var(--pm-subtext);">Created On: <%= new Date(project.createdOn).toLocaleDateString() %></p>

  <div style="margin-top: 1.5rem;">
    <% if (project.createdBy.toString() !== currentUserId.toString()) { %>
      <form action="/project/apply/<%= project._id %>" method="POST">
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>
        <button type="submit" class="pm-btn pm-btn-primary" style="width: 100%;">Apply</button>
      </form>
    <% } else { %>
      <div class="pm-info-banner" style="text-align: center; padding: 0.75rem;">
        <small>You created this project</small>
      </div>
    <% } %>
  </div>
</div>
